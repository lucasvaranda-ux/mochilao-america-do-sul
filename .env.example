# =====================================================================
#  MODELO de variáveis — copie pra um arquivo ".env" e preencha os valores.
#  O ".env" real está no .gitignore e NÃO vai pro GitHub. Este .example vai.
#  NUNCA coloque chaves reais neste .example.
# =====================================================================

# ---- Supabase (Mural) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ---- Vercel (deploy) ----
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# ---- Cloudflare (DNS do madeinbr.app) ----
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
